[Unit]
Description=Injection monitor Telegram mold bot
After=network-online.target injection-monitor.service
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/injection-monitor/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/injection-monitor/backend/.venv/bin/python -m app.bot.runner
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
